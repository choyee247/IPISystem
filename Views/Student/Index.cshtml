@model X.PagedList.IPagedList<ProjectManagementSystem.Models.StudentWithProjectViewModel>

@{
    ViewData["Title"] = "Student Management";
    Layout = "~/Views/Shared/_TeacherLayout.cshtml";
    var primaryColor = "#8c5dd1";
}

<h2 class="mb-4" style="color:@primaryColor;">Student Management</h2>

<!-- Filter & Search Form -->
<form method="get" class="mb-4 d-flex gap-2 align-items-center">
    <input type="text" name="searchString" value="@ViewBag.SearchString" placeholder="Search Name, Roll, Email" class="form-control w-auto" />

    <select id="yearSelect" name="yearId" class="form-select w-auto">
        <option value="">-- All Years --</option>
        @foreach (var year in (List<ProjectManagementSystem.DBModels.AcademicYear>)ViewBag.AcademicYears)
        {
            if (ViewBag.SelectedYear != null && (int)ViewBag.SelectedYear == year.AcademicYearPkId)
            {
                <option value="@year.AcademicYearPkId" selected>@year.YearRange</option>
            }
            else
            {
                <option value="@year.AcademicYearPkId">@year.YearRange</option>
            }
        }
    </select>

    <button type="submit" class="btn" style="background-color:@primaryColor; color:white;">Filter</button>
</form>

<!-- Students Table -->
<table class="table table-bordered table-striped">
    <thead class="text-white" style="background-color:@primaryColor;">
        <tr>
            <th>#</th>
            <th>Student Name</th>
            <th>Roll Number</th>
            <th>Email</th>
            <th>Department</th>
            <th>Academic Year</th>
            <th>Has Project</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            int index = ((Model.PageNumber - 1) * Model.PageSize) + 1;
            foreach (var s in Model)
            {
                <tr>
                    <td>@index</td>
                    <td>@s.StudentName</td>
                    <td>@s.RollNumber</td>
                    <td>@s.Email</td>
                    <td>@s.DepartmentName</td>
                    <td>@s.AcademicYear</td>
                    <td>
                        @if (s.HasProject)
                        {
                            <span class="badge bg-success">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Detail" asp-route-id="@s.StudentPkId" class="btn btn-sm btn-info text-white">Detail</a>
                    </td>
                </tr>
                index++;
            }
        }
        else
        {
            <tr>
                <td colspan="10" class="text-center">No students found.</td>
            </tr>
        }
    </tbody>
</table>

<!-- Pagination -->
@if (Model.PageCount > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            @if (Model.HasPreviousPage)
            {
                <li class="page-item">
                    <a class="page-link" asp-route-page="@(Model.PageNumber - 1)" asp-route-yearId="@(ViewBag.SelectedYear)" asp-route-searchString="@(ViewBag.SearchString)">Previous</a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">Previous</span></li>
            }

            @for (int i = 1; i <= Model.PageCount; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-route-page="@i" asp-route-yearId="@(ViewBag.SelectedYear)" asp-route-searchString="@(ViewBag.SearchString)">@i</a>
                </li>
            }

            @if (Model.HasNextPage)
            {
                <li class="page-item">
                    <a class="page-link" asp-route-page="@(Model.PageNumber + 1)" asp-route-yearId="@(ViewBag.SelectedYear)" asp-route-searchString="@(ViewBag.SearchString)">Next</a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">Next</span></li>
            }
        </ul>
    </nav>
}
