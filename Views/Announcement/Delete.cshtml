@model ProjectManagementSystem.DBModels.Announcement

@{
    ViewData["Title"] = "Delete Announcement";
    Layout = "~/Views/Shared/_TeacherLayout.cshtml";
}
<style>
    body {
        background: linear-gradient(135deg, #e4eefd, #ffffff);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
</style>

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header text-white" style="background-color:#8c5dd1;">
            <h4 class="mb-0">🗑️ Delete Announcement</h4>
        </div>

        <div class="card-body">
            <h5 class="text-danger">Are you sure you want to delete this announcement?</h5>
            <p class="text-muted mb-4">This action cannot be undone.</p>

            <div class="mb-3">
                <label class="fw-bold">Title:</label>
                <p>@Model.Title</p>
            </div>

            <div class="mb-3">
                <label class="fw-bold">Message:</label>
                <p>@Model.Message</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.FilePath))
            {
                <div class="mb-3">
                    <label class="fw-bold">Attached File:</label><br />
                    <a href="@Model.FilePath" target="_blank" class="btn btn-sm btn-outline-primary">
                        View File
                    </a>
                </div>
            }

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="AnnouncementId" />

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash"></i> Delete
                    </button>

                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
