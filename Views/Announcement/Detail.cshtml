@using ProjectManagementSystem.DBModels
@model Announcement
@{
    ViewData["Title"] = "Announcement Detail";
    Layout = "~/Views/Shared/_TeacherLayout.cshtml";
}
<style>
    body {
        background: linear-gradient(135deg, #e4eefd, #ffffff);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
</style>

<div class="container my-5" style="max-width: 800px;">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header text-white" style="background-color: #8C5DD1;">
            <h4 class="mb-0"><i class="bi bi-megaphone-fill me-2"></i>@Model.Title</h4>
        </div>

        <div class="card-body p-4 bg-light">
            <div class="mb-3 text-muted">
                <small>
                    <i class="bi bi-calendar-event me-1"></i>
                    Posted on @Model.CreatedDate?.ToString("dd MMM yyyy")
                </small>
                @if (Model.StartDate != null && Model.ExpiryDate != null)
                {
                    <div>
                        <small>
                            <i class="bi bi-clock me-1"></i>
                            Active: @Model.StartDate?.ToString("dd MMM yyyy") → @Model.ExpiryDate?.ToString("dd MMM yyyy")
                        </small>
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(Model.Message)) 
            {
                <p class="fs-5 text-dark" style="white-space: pre-line;">
                    @Model.Message
                </p>
            }

            @* @if (!string.IsNullOrEmpty(Model.FilePath))
            {
                <div class="mt-3">
                    <a href="@Model.FilePath" target="_blank" class="btn btn-outline-primary">
                        <i class="bi bi-paperclip me-1"></i> View Attachment
                    </a>
                </div>
            } *@
            @* @if (!string.IsNullOrEmpty(Model.FilePath))
            {
                <div class="mt-3">
                    <a href="@Url.Content("~/uploads/announcements/" + Model.FilePath)"
                       target="_blank"
                       class="btn btn-outline-primary">
                        <i class="bi bi-paperclip me-1"></i> View Attachment
                    </a>
                </div>
            } *@
            @if (!string.IsNullOrEmpty(Model.FilePath))
            {
                <div class="mt-3">
                    <a href="@Url.Content("~/uploads/announcements/" + Model.FilePath)"
                       class="btn btn-outline-primary"
                       download>
                        <i class="bi bi-paperclip me-1"></i> Download Attachment
                    </a>
                </div>
            }
            @if (Model.BlocksSubmissions==true)
            {
                <div class="alert alert-danger mt-4 mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Project submissions are temporarily blocked during this announcement period.
                </div>
            }
        </div>


        <div class="card-footer text-end bg-white">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Announcements
            </a>
        </div>
    </div>
</div>
