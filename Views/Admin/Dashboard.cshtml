@* <script src="https://cdn.jsdelivr.net/npm/chart.js"></script> *@
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Activity Chart
        const ctx1 = document.getElementById('activityChart')?.getContext('2d');
        if (ctx1) {
            new Chart(ctx1, {
                type: 'line',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        label: 'Projects',
                        data: [12, 19, 15, 17, 14, 13, 15],
                        borderColor: '#8c5dd1',
                        backgroundColor: 'rgba(140, 93, 209, 0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        }

        // Distribution Chart
        const ctx2 = document.getElementById('distributionChart')?.getContext('2d');
        if (ctx2) {
            new Chart(ctx2, {
                type: 'doughnut',
                data: {
                    labels: ['Teachers', 'Students', 'Projects'],
                    datasets: [{
                        data: [@Model.TotalTeachers, @Model.TotalStudents, @Model.TotalProjects],
                        backgroundColor: ['#8c5dd1', '#b794f4', '#d6bcfa'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });
        }
    });
</script>