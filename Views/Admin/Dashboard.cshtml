@model ProjectManagementSystem.DBModels.AdminDashboardViewModel
@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = "Dashboard Overview";
    ViewData["Breadcrumb"] = "Home / Dashboard";
}

<!-- Modern Dashboard Design -->
<div class="dashboard-container">

    <!-- Header Section with Gradient -->
    <div class="dashboard-header mb-4">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="display-6 fw-bold text-purple">
                    <i class="bi bi-grid-3x3-gap-fill me-2"></i>Dashboard
                </h1>
                @* <p class="text-muted mb-0">
                    <i class="bi bi-calendar-check me-2"></i>
                    @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
                </p> *@
            </div>
            <div class="col-md-6">
                <!-- Academic Year Filter - Modern Design -->
                <div class="filter-wrapper float-md-end">
                    <form method="get" asp-action="Dashboard" class="filter-form">
                        <div class="input-group glass-filter">
                            <span class="input-group-text bg-transparent border-0 text-purple">
                                <i class="bi bi-funnel-fill"></i>
                            </span>
                            <select class="form-select border-0 bg-transparent" name="AcademicYearPkId" onchange="this.form.submit()">
                                <option value="">All Academic Years</option>
                                @foreach (var year in Model.AcademicYears)
                                {
                                    <option value="@year.AcademicYearPkId" selected="@(Model.SelectedYearPkId == year.AcademicYearPkId)">
                                        @year.YearRange
                                    </option>
                                }
                            </select>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Welcome Banner -->
    <div class="welcome-banner mb-4">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h2 class="h3 mb-2">
                    Welcome back, <span class="text-purple fw-bold">@ViewBag.FullName</span>
                </h2>
                <p class="mb-0 text-muted">
                    <i class="bi bi-graph-up-arrow me-2 text-purple"></i>
                    Here's what's happening with your projects today.
                </p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <span class="badge bg-soft-purple px-3 py-2">
                    <i class="bi bi-moon-stars me-2"></i>Last updated: just now
                </span>
            </div>
        </div>
    </div>

    <!-- Metrics Cards - Modern Design -->
    <div class="row g-4 mb-4">
        <!-- Total Teachers Card -->
        <div class="col-xl-3 col-md-6">
            <div class="modern-card teacher-card">
                <div class="card-content">
                    <div class="card-icon-wrapper">
                        <i class="bi bi-person-video3"></i>
                    </div>
                    <div class="card-stats">
                        <span class="stats-label">Total Teachers</span>
                        <h3 class="stats-number">@Model.TotalTeachers</h3>
                        <span class="stats-trend">
                            <i class="bi bi-arrow-up-short"></i> Faculty
                        </span>
                    </div>
                </div>
                <div class="card-footer-bg"></div>
            </div>
        </div>

        <!-- Total Students Card -->
        <div class="col-xl-3 col-md-6">
            <div class="modern-card student-card">
                <div class="card-content">
                    <div class="card-icon-wrapper">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <div class="card-stats">
                        <span class="stats-label">Total Students</span>
                        <h3 class="stats-number">@Model.TotalStudents</h3>
                        <span class="stats-trend">
                            <i class="bi bi-arrow-up-short"></i> Enrolled
                        </span>
                    </div>
                </div>
                <div class="card-footer-bg"></div>
            </div>
        </div>

        <!-- Total Projects Card -->
        <div class="col-xl-3 col-md-6">
            <div class="modern-card project-card">
                <div class="card-content">
                    <div class="card-icon-wrapper">
                        <i class="bi bi-folder-symlink-fill"></i>
                    </div>
                    <div class="card-stats">
                        <span class="stats-label">Active Projects</span>
                        <h3 class="stats-number">@Model.TotalProjects</h3>
                        <span class="stats-trend">
                            <i class="bi bi-arrow-up-short"></i> In Progress
                        </span>
                    </div>
                </div>
                <div class="card-footer-bg"></div>
            </div>
        </div>

        <!-- Announcements Card -->
        <div class="col-xl-3 col-md-6">
            <div class="modern-card announcement-card">
                <div class="card-content">
                    <div class="card-icon-wrapper">
                        <i class="bi bi-megaphone-fill"></i>
                    </div>
                    <div class="card-stats">
                        <span class="stats-label">Announcements</span>
                        <h3 class="stats-number">@Model.TotalAnnouncements</h3>
                        <span class="stats-trend">
                            <i class="bi bi-arrow-up-short"></i> Total Posts
                        </span>
                    </div>
                </div>
                <div class="card-footer-bg"></div>
            </div>
        </div>
    </div>

    <!-- Charts Row (Optional - Add if you want charts) -->
    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="glass-card h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-bar-chart-fill text-purple me-2"></i>
                            Activity Overview
                        </h5>
                        <div class="chart-actions">
                            <span class="badge bg-soft-purple me-2">Weekly</span>
                            <span class="badge bg-light text-dark">Monthly</span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <canvas id="activityChart" height="100"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="glass-card h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="mb-0">
                        <i class="bi bi-pie-chart-fill text-purple me-2"></i>
                        Distribution
                    </h5>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <canvas id="distributionChart" height="150"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Teachers Table - Modern Design -->
    <div class="glass-card mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-person-badge-fill text-purple me-2"></i>
                    Recent Teachers
                </h5>
                <div class="header-actions">
                    <span class="badge bg-soft-purple me-2">Latest 3</span>
                    <a asp-controller="Teacher" asp-action="Index" class="btn btn-sm btn-outline-purple">
                        View All <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table modern-table mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Teacher</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Academic Year</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentTeachers.Any())
                        {
                            int i = 1;
                            foreach (var teacher in Model.RecentTeachers.Take(3))
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-soft-purple rounded-circle px-3 py-2">@i</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle bg-purple me-2">
                                                @teacher.FullName.Substring(0, 1)
                                            </div>
                                            <div>
                                                <h6 class="mb-0">@teacher.FullName</h6>
                                                <small class="text-muted">ID: @teacher.Id</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@teacher.Email</td>
                                    <td><span class="badge bg-soft-purple">@teacher.DepartmentName</span></td>
                                    <td>@teacher.AcademicYearName</td>
                                    <td>
                                        @if (teacher.IsActive)
                                        {
                                            <span class="status-badge active">
                                                <i class="bi bi-check-circle-fill me-1"></i>Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge inactive">
                                                <i class="bi bi-x-circle-fill me-1"></i>Inactive
                                            </span>
                                        }
                                    </td>
                                </tr>
                                i++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4">
                                    <div class="empty-state">
                                        <i class="bi bi-people display-4 text-muted"></i>
                                        <p class="text-muted mt-2">No teachers found</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Recent Students Table - Modern Design -->
    <div class="glass-card mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-mortarboard-fill text-purple me-2"></i>
                    Recent Students
                </h5>
                <div class="header-actions">
                    <span class="badge bg-soft-purple me-2">Latest 3</span>
                    <a asp-controller="Student" asp-action="Index" class="btn btn-sm btn-outline-purple">
                        View All <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table modern-table mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Student</th>
                            <th>Email</th>
                            <th>Academic Year</th>
                            <th>Projects</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentStudents.Any())
                        {
                            int i = 1;
                            foreach (var student in Model.RecentStudents.Take(3))
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-soft-purple rounded-circle px-3 py-2">@i</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle bg-purple me-2">
                                                @student.FullName.Substring(0, 1)
                                            </div>
                                            <div>
                                                <h6 class="mb-0">@student.FullName</h6>
                                                <small class="text-muted">ID: @student.Id</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@student.Email</td>
                                    <td>@student.AcademicYearName</td>
                                    <td>
                                        <span class="badge bg-soft-purple">
                                            @student.ProjectCount Project@(student.ProjectCount > 1 ? "s" : "")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="status-badge active">
                                            <i class="bi bi-check-circle-fill me-1"></i>Active
                                        </span>
                                    </td>
                                </tr>
                                i++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4">
                                    <div class="empty-state">
                                        <i class="bi bi-person-x display-4 text-muted"></i>
                                        <p class="text-muted mt-2">No students found</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Recent Announcements Section - Modern Design -->
    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="glass-card h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-megaphone-fill text-purple me-2"></i>
                            Recent Announcements
                        </h5>
                        <a asp-controller="Announcement" asp-action="Create" class="btn btn-purple btn-sm">
                            <i class="bi bi-plus-lg me-1"></i>New Announcement
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.RecentAnnouncements.Any())
                    {
                        <div class="announcement-list">
                            @foreach (var ann in Model.RecentAnnouncements.Take(3))
                            {
                                <div class="announcement-item">
                                    <div class="announcement-icon">
                                        <i class="bi bi-megaphone"></i>
                                    </div>
                                    <div class="announcement-content">
                                        <h6 class="mb-1">@ann.Title</h6>
                                        <div class="announcement-meta">
                                            <span class="badge bg-soft-purple me-2">
                                                <i class="bi bi-tag me-1"></i>General
                                            </span>
                                            <small class="text-muted">
                                                <i class="bi bi-clock me-1"></i>
                                                @ann.CreatedDate?.ToString("dd MMM yyyy")
                                            </small>
                                        </div>
                                    </div>
                                    <div class="announcement-actions">
                                        <button class="btn btn-sm btn-link text-purple">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state py-4">
                            <i class="bi bi-megaphone display-4 text-muted"></i>
                            <p class="text-muted mt-2">No announcements yet</p>
                            <a asp-action="Create" class="btn btn-purple btn-sm mt-2">
                                <i class="bi bi-plus-lg me-1"></i>Create First Announcement
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Quick Actions Card -->
        <div class="col-lg-6">
            <div class="glass-card h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="mb-0">
                        <i class="bi bi-lightning-charge-fill text-purple me-2"></i>
                        Quick Actions
                    </h5>
                </div>
                <div class="card-body">
                    <div class="quick-actions-grid">
                        <a asp-controller="Teacher" asp-action="Create" class="quick-action-item">
                            <div class="quick-action-icon bg-soft-purple">
                                <i class="bi bi-person-plus-fill text-purple"></i>
                            </div>
                            <span>Add Teacher</span>
                        </a>

                        <a asp-controller="Email" asp-action="Create" class="quick-action-item">
                            <div class="quick-action-icon bg-soft-purple">
                                <i class="bi bi-person-plus-fill text-purple"></i>
                            </div>
                            <span>Add Student Email</span>
                        </a>

                        <a asp-controller="ProjectApproval" asp-action="Index" class="quick-action-item">
                            <div class="quick-action-icon bg-soft-purple">
                                <i class="bi bi-arrow-up-short text-purple"></i>
                            </div>
                            <span>Project Approval</span>
                        </a>

                        <a asp-controller="Announcement" asp-action="Create" class="quick-action-item">
                            <div class="quick-action-icon bg-soft-purple">
                                <i class="bi bi-megaphone-fill text-purple"></i>
                            </div>
                            <span>Announcement</span>
                        </a>

                        <a asp-controller="Admin" asp-action="AddEvent" class="quick-action-item">
                            <div class="quick-action-icon bg-soft-purple">
                                <i class="bi bi-calendar-plus-fill text-purple"></i>
                            </div>
                            <span>Add Event</span>
                        </a>

                        <a asp-controller="Admin" asp-action="GenerateReport" class="quick-action-item">
                            <div class="quick-action-icon bg-soft-purple">
                                <i class="bi bi-file-earmark-spreadsheet-fill text-purple"></i>
                            </div>
                            <span>Generate Report</span>
                        </a>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pb-4 px-4">
                    <div class="progress" style="height: 8px;">
                        <div class="progress-bar bg-purple" style="width: 75%"></div>
                    </div>
                    <small class="text-muted mt-2 d-block">75% of monthly goals achieved</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modern CSS Styles -->
<style>
    :root {
        --primary-purple: #8c5dd1;
        --primary-purple-light: rgba(140, 93, 209, 0.1);
        --primary-purple-soft: rgba(140, 93, 209, 0.4);
        --primary-purple-dark: #6b3fa0;
        --gradient-purple: linear-gradient(135deg, #8c5dd1 0%, #a77be0 100%);
    }

    /* Global Styles */
    .dashboard-container {
        padding: 1.5rem;
        background: linear-gradient(135deg, #f6f9fc 0%, #ffffff 100%);
        min-height: 100vh;
    }

    /* Text Colors */
    .text-purple {
        color: var(--primary-purple) !important;
    }

    .bg-purple {
        background: var(--primary-purple) !important;
    }

    .bg-soft-purple {
        background: var(--primary-purple-soft) !important;
    }

    /* Modern Filter */
    .filter-wrapper {
        background: white;
        border-radius: 50px;
        padding: 0.35rem;
        box-shadow: 0 4px 15px rgba(140, 93, 209, 0.1);
    }

    .glass-filter {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(140, 93, 209, 0.2);
        border-radius: 50px;
        padding: 0.25rem;
    }

        .glass-filter select {
            cursor: pointer;
            font-weight: 500;
            color: var(--primary-purple);
            padding: 0.5rem 1rem;
        }

            .glass-filter select:focus {
                box-shadow: none;
            }

    /* Welcome Banner */
    .welcome-banner {
        background: white;
        border-radius: 20px;
        padding: 1.5rem 2rem;
        box-shadow: 0 8px 25px rgba(140, 93, 209, 0.08);
        border: 1px solid rgba(140, 93, 209, 0.1);
    }

    /* Modern Cards */
    .modern-card {
        background: white;
        border-radius: 20px;
        padding: 1.5rem;
        box-shadow: 0 8px 25px rgba(140, 93, 209, 0.08);
        border: 1px solid rgba(140, 93, 209, 0.1);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

        .modern-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(140, 93, 209, 0.15);
        }

        .modern-card .card-content {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            position: relative;
            z-index: 2;
        }

        .modern-card .card-icon-wrapper {
            width: 70px;
            height: 70px;
            background: var(--gradient-purple);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            color: white;
            box-shadow: 0 10px 20px rgba(140, 93, 209, 0.3);
        }

        .modern-card .card-stats {
            flex: 1;
        }

        .modern-card .stats-label {
            font-size: 0.9rem;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .modern-card .stats-number {
            font-size: 2.5rem;
            font-weight: 700;
            color: #2d3748;
            margin: 0;
            line-height: 1.2;
        }

        .modern-card .stats-trend {
            font-size: 0.8rem;
            color: #28a745;
        }

        .modern-card .card-footer-bg {
            position: absolute;
            bottom: -20px;
            right: -20px;
            width: 150px;
            height: 150px;
            background: rgba(140, 93, 209, 0.03);
            border-radius: 50%;
            z-index: 1;
        }

    /* Card Variations */
    .teacher-card .card-icon-wrapper {
        background: linear-gradient(135deg, #8c5dd1, #b794f4);
    }

    .student-card .card-icon-wrapper {
        background: linear-gradient(135deg, #8c5dd1, #9f7aea);
    }

    .project-card .card-icon-wrapper {
        background: linear-gradient(135deg, #8c5dd1, #b794f4);
    }

    .announcement-card .card-icon-wrapper {
        background: linear-gradient(135deg, #8c5dd1, #d6bcfa);
    }

    /* Glass Card */
    .glass-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 8px 30px rgba(140, 93, 209, 0.08);
        border: 1px solid rgba(140, 93, 209, 0.1);
        overflow: hidden;
    }

    /* Modern Table */
    .modern-table {
        margin-bottom: 0;
    }

        .modern-table thead th {
            background: var(--primary-purple-light);
            color: var(--primary-purple);
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid var(--primary-purple);
            padding: 1rem;
        }

        .modern-table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-bottom: 1px solid rgba(140, 93, 209, 0.1);
        }

        .modern-table tbody tr:hover {
            background: rgba(140, 93, 209, 0.02);
        }

    /* Avatar */
    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        text-transform: uppercase;
    }

    /* Status Badge */
    .status-badge {
        padding: 0.35rem 1rem;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 500;
    }

        .status-badge.active {
            background: rgba(40, 167, 69, 0.1);
            color: #28a745;
        }

    /* Button Outline Purple */
    .btn-outline-purple {
        color: var(--primary-purple);
        border: 1px solid var(--primary-purple);
        border-radius: 50px;
        padding: 0.35rem 1.2rem;
        transition: all 0.3s;
    }

        .btn-outline-purple:hover {
            background: var(--primary-purple);
            color: white;
        }

    .btn-purple {
        background: var(--primary-purple);
        color: white;
        border: none;
        border-radius: 50px;
        padding: 0.35rem 1.2rem;
        transition: all 0.3s;
    }

        .btn-purple:hover {
            background: var(--primary-purple-dark);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(140, 93, 209, 0.3);
        }

    /* Announcement List */
    .announcement-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .announcement-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: rgba(140, 93, 209, 0.02);
        border-radius: 12px;
        transition: all 0.3s;
        border: 1px solid transparent;
    }

        .announcement-item:hover {
            background: white;
            border-color: rgba(140, 93, 209, 0.2);
            box-shadow: 0 5px 15px rgba(140, 93, 209, 0.1);
        }

    .announcement-icon {
        width: 45px;
        height: 45px;
        background: var(--primary-purple-light);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-purple);
        font-size: 1.3rem;
    }

    .announcement-content {
        flex: 1;
    }

    .announcement-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    /* Quick Actions Grid */
    .quick-actions-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        padding: 1rem;
    }

    .quick-action-item {
        text-align: center;
        text-decoration: none;
        color: #495057;
        transition: all 0.3s;
        padding: 1rem 0.5rem;
        border-radius: 12px;
    }

        .quick-action-item:hover {
            background: var(--primary-purple-light);
            transform: translateY(-3px);
            text-decoration: none;
            color: var(--primary-purple);
        }

    .quick-action-icon {
        width: 50px;
        height: 50px;
        margin: 0 auto 0.5rem;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 2rem;
    }

    /* Progress Bar */
    .progress-bar.bg-purple {
        background: var(--gradient-purple) !important;
    }

    .status-badge.active {
        background-color: #e6f9f0;
        color: #1a7f5a;
        padding: 6px 10px;
        border-radius: 20px;
    }

    .status-badge.inactive {
        background-color: #fdeaea;
        color: #c0392b;
        padding: 6px 10px;
        border-radius: 20px;
    }
    /* Responsive */
    @@media (max-width: 768px) {
        .dashboard-container {
            padding: 1rem;
        }

        .modern-card .card-content {
            flex-direction: column;
            text-align: center;
        }

        .quick-actions-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    /* Animations */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .modern-card, .glass-card {
        animation: fadeInUp 0.5s ease;
    }
</style>
