@model ProjectManagementSystem.DBModels.AdminDashboardViewModel
@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid py-4">
    <!-- Dashboard Header -->
    <div class="dashboard-header mb-4">
        <h1 class="fw-bold text-purple">Admin Dashboard</h1>
        <p class="text-muted">Control panel & analytics</p>
    </div>

    <!-- Metrics Cards -->
    <div class="row g-4 mb-4">
        <!-- Total Teachers -->
        <div class="col-md-6 col-lg-4">
            <div class="stat-card bg-purple-light">
                <div class="stat-icon"><i class="bi bi-person"></i></div>
                <div class="stat-content">
                    <span>Total Teachers</span>
                    <h3>@Model.TotalTeachers</h3>
                </div>
            </div>
        </div>

        <!-- Total Projects -->
        <div class="col-md-6 col-lg-4">
            <div class="stat-card bg-purple-light">
                <div class="stat-icon"><i class="bi bi-folder"></i></div>
                <div class="stat-content">
                    <span>Total Projects</span>
                    <h3>@Model.TotalProjects</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Teachers Table -->
    <div class="card glass-card">
        <div class="card-header bg-purple text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Recent Teachers</h5>
            <span class="badge bg-light text-purple">Latest</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead class="table-purple">
                    <tr>
                        <th>#</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentTeachers != null && Model.RecentTeachers.Count > 0)
                    {
                        int i = 1;
                        foreach (var teacher in Model.RecentTeachers)
                        {
                            <tr>
                                <td>@i</td>
                                <td>@teacher.FullName</td>
                                <td>@teacher.Email</td>
                                
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">No teachers found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .text-purple {
        color: #8C5DD1 !important;
    }

    .bg-purple {
        background-color: #8C5DD1 !important;
        color: #fff;
    }

    .bg-purple-light {
        background-color: rgba(140, 93, 209, 0.1);
        color: #8C5DD1;
    }

    .stat-card {
        background: #fff;
        border-radius: 15px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        box-shadow: 0 8px 20px rgba(140, 93, 209, 0.1);
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(140, 93, 209, 0.2);
        }

    .stat-icon {
        font-size: 2.5rem;
    }

    .stat-content span {
        font-weight: 500;
    }

    .stat-content h3 {
        font-size: 2rem;
        margin: 0;
    }

    .glass-card {
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(140, 93, 209, 0.1);
    }

    .table-purple th {
        background-color: #8C5DD1;
        color: #fff;
    }
</style>
