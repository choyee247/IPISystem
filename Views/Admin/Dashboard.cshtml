@model ProjectManagementSystem.DBModels.AdminDashboardViewModel
@{
    Layout = "_TeacherLayout"; // Make sure you have a layout file named _AdminLayout.cshtml
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid p-4">
    <h1 class="mb-4">Admin Dashboard</h1>

    <div class="row">
        <!-- Total Teachers Card -->
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Teachers</h5>
                    <p class="card-text display-4">@Model.TotalTeachers</p>
                    <i class="bx bx-user bx-lg"></i>
                </div>
            </div>
        </div>

        <!-- Total Projects Card -->
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Projects</h5>
                    <p class="card-text display-4">@Model.TotalProjects</p>
                    <i class="bx bx-folder bx-lg"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Teachers -->
    <div class="row mt-4">
        <div class="col-md-12">
            <h3>Recent Teachers</h3>
            <table class="table table-striped table-bordered mt-2">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Joined Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.RecentTeachers != null && Model.RecentTeachers.Count > 0)
                    {
                        int i = 1;
                        foreach (var teacher in Model.RecentTeachers)
                        {
                            <tr>
                                <td>@i</td>
                                <td>@teacher.FullName</td>
                                <td>@teacher.Email</td>
                                @* <td>@teacher.Phone</td>
                                <td>@teacher.CreatedAt?.ToString("dd/MM/yyyy")</td> *@
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">No teachers found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
