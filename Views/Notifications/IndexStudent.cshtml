@model IEnumerable<ProjectManagementSystem.DBModels.NotificationViewModel>

@{
    ViewData["Title"] = "Your Notifications";
}

<h2 class="mb-3">Your Notifications</h2>

<!-- Counters + Mark all as read button -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <span class="fw-bold">Unread:</span>
       @*  <span id="
">@Model.Count(n => n.IsRead==false)</span>

        <span class="ms-3 fw-bold">Read:</span>
        <span id="readCount">@Model.Count(n => n.IsRead==true)</span> *@
        <span id="unreadCount">@Model.Count(n => n.IsRead == false)</span>
        <span class="ms-3 fw-bold">Read:</span>
        <span id="readCount">@Model.Count(n => n.IsRead == true)</span>
    </div>

    <button class="btn btn-sm btn-primary" id="markAllReadBtn">Mark All as Read</button>
</div>

<style>

    body {
        background: linear-gradient(135deg, #e4eefd);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    /* Tab styling */
    .noti-tab {
        display: inline-block;
        padding: 10px 18px;
        margin-right: 8px;
        background: #e9ddff;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        color: #5d33a6;
        border: 1px solid transparent;
        transition: 0.2s;
    }

        .noti-tab.active {
            background: #8c5dd1;
            color: white;
            border-color: #6d3fb7;
        }

        .noti-tab:hover {
            background: #d9c5ff;
        }

    /* Notification list styling */
    .noti-panel li {
        transition: background 0.3s;
    }

        .noti-panel li.unread {
            background-color: #f3e8ff; /* Light purple for unread */
            color: #5d33a6;
            font-weight: 600;
        }

        .noti-panel li.read {
            background-color: #f8f9fa; /* Light grey for read */
            color: #6c757d;
            font-weight: normal;
        }

        .noti-panel li:hover {
            background-color: #e0d0ff;
        }

    .noti-badge {
        background-color: #8c5dd1 !important;
        color: white !important;
    }
</style>

<!-- Horizontal Tabs -->
<div class="mb-3">
    @foreach (var group in Model.GroupBy(n => n.NotificationType))
    {
        <span class="noti-tab" onclick="showTab('@group.Key')" id="tab-@group.Key">
            @group.Key (@group.Count())
        </span>
    }
</div>

<!-- Notification Lists -->
@foreach (var group in Model.GroupBy(n => n.NotificationType))
{
    <ul class="list-group mb-4 noti-panel" id="panel-@group.Key" style="display:none;">
        @foreach (var noti in group)
        {
           @*  <li class="list-group-item d-flex justify-content-between align-items-start @(noti.IsRead==true ? "read" : "unread")">
                <div class="ms-2 me-auto">
                    <div class="fw-bold">@noti.Title</div>
                    <div>@noti.Message</div>

                    @if (noti.ProjectId.HasValue)
                    {
                        <small class="text-muted">
                            Project:
                            <a href="javascript:void(0)" onclick="openDetail(@noti.Id)">
                                @noti.ProjectName
                            </a>
                        </small>
                    }
                    else
                    {
                        <a href="javascript:void(0)" onclick="openDetail(@noti.Id)">
                            View Details
                        </a>
                    }

                    <br />
                    <small class="text-muted">@noti.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>
                </div>
                <span class="badge noti-badge rounded-pill">@noti.NotificationType</span>
            </li> *@
            <li class="list-group-item d-flex justify-content-between align-items-start @(noti.IsRead==true ? "read" : "unread")">
                @* <div class="ms-2 me-auto">
                    @if (noti.NotificationType == "Announcement")
                    {
                        <!-- Show Announcement Title and Message -->
                        <div class="fw-bold">@noti.Title - @noti.Message</div>
                        <div>@noti.AnnouncementMessage</div> <!-- Optional if you have separate property -->
                    }
                    else
                    {
                        <div class="fw-bold">@noti.Title</div>
                        <div>@noti.Message</div>
                    }

                    @if (noti.ProjectId.HasValue)
                    {
                        <small class="text-muted">
                            Project:
                            <a href="javascript:void(0)" onclick="openDetail(@noti.Id)">
                                @noti.ProjectName
                            </a>
                        </small>
                    }
                    else
                    {
                        <a href="javascript:void(0)" onclick="openDetail(@noti.Id)">
                            View Details
                        </a>
                    }

                    <br />
                    <small class="text-muted">@noti.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>
                </div> *@
                <div class="ms-2 me-auto">
                    @if (noti.NotificationType == "Announcement")
                    {
                        <!-- Always show Announcement Title + Message -->
                        <div class="fw-bold">@noti.Title</div>
                        <div>@noti.AnnouncementMessage</div>

                        <!-- Link to view Announcement details -->
                        <a href="javascript:void(0)" onclick="openDetail(@noti.Id)">
                            View Details
                        </a>
                    }
                    else
                    {
                        <!-- For normal notifications -->
                        <div class="fw-bold">@noti.Title</div>
                        <div>@noti.Message</div>

                        @if (noti.ProjectId.HasValue)
                        {
                            <small class="text-muted">
                                Project:
                                <a href="javascript:void(0)" onclick="openDetail(@noti.Id)">
                                    @noti.ProjectName
                                </a>
                            </small>
                        }
                        else
                        {
                            <a href="javascript:void(0)" onclick="openDetail(@noti.Id)">
                                View Details
                            </a>
                        }
                    }

                    <br />
                    <small class="text-muted">@noti.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>
                </div>
                <span class="badge noti-badge rounded-pill">@noti.NotificationType</span>
            </li>
        }
    </ul>
}

@section Scripts {
    <script>
        // ✅ URLs from Razor (IMPORTANT)
        const markReadUrl = '@Url.Action("MarkAsRead", "Notifications")';
        const detailUrl = '@Url.Action("Details", "Notifications")';
        const unreadUrl = '@Url.Action("GetUnreadCount", "Notifications")';
        const readUrl = '@Url.Action("GetReadCount", "Notifications")';
        const markAllUrl = '@Url.Action("MarkAllRead", "Notifications")';

        // ✅ Open detail + mark as read
        function openDetail(id) {
            fetch(markReadUrl + '?id=' + id, { method: "POST" })
                .then(() => {
                    window.location.href = detailUrl + '/' + id;
                });
        }

        // ✅ Update unread/read counters (NO reload)
        function loadCounts() {
            fetch(unreadUrl)
                .then(r => r.json())
                .then(count => {
                    document.getElementById("unreadCount").innerText = count;
                });

            fetch(readUrl)
                .then(r => r.json())
                .then(count => {
                    document.getElementById("readCount").innerText = count;
                });
        }

        // ✅ Mark all as read (NO full reload)
        document.getElementById("markAllReadBtn").addEventListener("click", function () {
            fetch(markAllUrl, { method: "POST" })
                .then(() => {
                    // UI update without reload
                    document.querySelectorAll(".noti-panel li").forEach(li => {
                        li.classList.remove("unread");
                        li.classList.add("read");
                    });

                    loadCounts();
                });
        });

        // ✅ Tabs
        function showTab(type) {
            document.querySelectorAll(".noti-panel").forEach(p => p.style.display = "none");
            document.querySelectorAll(".noti-tab").forEach(t => t.classList.remove("active"));

            document.getElementById("panel-" + type).style.display = "block";
            document.getElementById("tab-" + type).classList.add("active");
        }

        // ✅ Default first tab
        let firstTab = document.querySelector(".noti-tab");
        if (firstTab) {
            showTab(firstTab.id.replace("tab-", ""));
        }
    </script>
}
