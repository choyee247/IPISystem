@model ProjectManagementSystem.DBModels.NotificationViewModel

@{
    ViewData["Title"] = "Notification Details";
}
<style>
    body {
    background: linear-gradient(135deg, #e4eefd);
    min-height: 100vh;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
</style>
<h2>@Model.Title</h2>

<div class="mb-3">
    <span class="badge bg-info">@Model.NotificationType</span>
    <small class="text-muted ms-2">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>
</div>

@if (Model.NotificationType == "Announcement")
{
    <h5>@Model.AnnouncementTitle</h5>
    <p>@Model.AnnouncementMessage</p>
    <p>
        <strong>Start Date:</strong> @Model.AnnouncementStartDate?.ToString("dd MMM yyyy") <br />
        <strong>Expiry Date:</strong> @Model.AnnouncementExpiryDate?.ToString("dd MMM yyyy") <br />
        <strong>Blocks Submissions:</strong> @(Model.AnnouncementBlocksSubmissions == true ? "Yes" : "No") <br />
        @if (!string.IsNullOrEmpty(Model.AnnouncementFilePath))
        {
            <strong>File:</strong> <a href="@Url.Content(Model.AnnouncementFilePath)" target="_blank">Download</a>
        }
    </p>
}
else
{
    <p>@Model.Message</p>
    @if (Model.ProjectId.HasValue)
    {
        <p>
            Related Project:
            <a href="@Url.Action("Details", "Project", new { id = Model.ProjectId.Value })">
                @Model.ProjectName
            </a>
        </p>
    }
}

<form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this notification?');">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger mt-3">Delete</button>
    <a class="btn btn-secondary mt-3" href="@Url.Action("IndexStudent")">Back to Notifications</a>
</form>
