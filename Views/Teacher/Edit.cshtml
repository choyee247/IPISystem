@model ProjectManagementSystem.DBModels.Teacher
@{
    Layout = "_TeacherLayout";
}
@{
    var academicYears = ViewBag.AcademicYears as List<ProjectManagementSystem.DBModels.AcademicYear> ?? new List<ProjectManagementSystem.DBModels.AcademicYear>();
    var departments = ViewBag.Departments as List<ProjectManagementSystem.DBModels.StudentDepartment> ?? new List<ProjectManagementSystem.DBModels.StudentDepartment>();
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <!-- Card Wrapper -->
            <div class="card shadow-lg border-0 rounded-4" style="border-top: 5px solid #8C5DD1;">
                <div class="card-header text-white text-center rounded-top-4" style="background-color: #8C5DD1;">
                    <h3 class="mb-0 fw-bold">Edit Teacher</h3>
                </div>
                <div class="card-body p-5">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Edit" asp-controller="Teacher" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <!-- Full Name -->
                        <div class="form-floating mb-4">
                            <input asp-for="FullName" class="form-control border-purple text-purple" placeholder="Full Name" />
                            <label asp-for="FullName" class="text-purple">Full Name</label>
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <!-- Email -->
                        <div class="form-floating mb-4">
                            <input asp-for="Email" type="email" class="form-control border-purple text-purple" placeholder="Email" />
                            <label asp-for="Email" class="text-purple">Email</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- Role -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Role</label>
                            <select asp-for="Role" class="form-select form-select-lg rounded-3">
                                <option value="">-- Select Role --</option>
                                <option value="Teacher">Teacher</option>
                                <option value="Admin">Admin</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>

                        <!-- Department -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Department</label>
                           <select asp-for="DepartmentPkId" class="form-select form-select-lg rounded-3">
                                <option value="">-- Select Department --</option>
                                @foreach (var d in departments)
                                {
                                    <option value="@d.DepartmentPkId">@d.DepartmentName</option>
                                }
                            </select>
                            <span asp-validation-for="DepartmentPkId" class="text-danger small"></span>
                        </div>

                        <!-- Academic Year -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Academic Year</label>
                            <select asp-for="AcademicYearPkId" class="form-select form-select-lg rounded-3">
                                <option value="">-- Select Academic Year --</option>
                                @foreach (var ay in academicYears)
                                {
                                    <option value="@ay.AcademicYearPkId">@ay.YearRange</option>
                                }
                            </select>
                            <span asp-validation-for="AcademicYearPkId" class="text-danger small"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" asp-controller="Teacher" 
                               class="btn btn-outline-secondary btn-lg rounded-pill px-4">
                                <i class="bi bi-x-circle me-1"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-purple btn-lg rounded-pill px-5">
                                <i class="bi bi-save me-1"></i> Save Changes
                            </button>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Purple Theme Styles */
    .text-purple {
        color: #8C5DD1 !important;
    }

    .border-purple {
        border-color: #8C5DD1 !important;
    }

    .form-control:focus {
        border-color: #8C5DD1;
        box-shadow: 0 0 0 0.2rem rgba(140, 93, 209, 0.25);
    }

    .form-select:focus {
        border-color: #8C5DD1;
        box-shadow: 0 0 0 0.2rem rgba(140, 93, 209, 0.25);
    }

    .btn-purple {
        background-color: #8C5DD1;
        color: #fff;
        border: none;
        transition: background-color 0.3s ease;
    }

    .btn-purple:hover {
        background-color: #6b3fa0;
        color: #fff;
    }
</style>
