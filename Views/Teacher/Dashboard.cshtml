<!-- Modern CSS Styles -->
<style>
    :root {
        --primary-purple: #8c5dd1;
        --primary-purple-light: rgba(140, 93, 209, 0.1);
        --primary-purple-soft: rgba(140, 50, 200, 0.5);
        --primary-purple-dark: #6b3fa0;
        --gradient-purple: linear-gradient(135deg, #8c5dd1 0%, #a77be0 100%);
    }

    /* Global Styles */
    .dashboard-container {
        padding: 1.5rem;
        background: linear-gradient(135deg, #f6f9fc 0%, #ffffff 100%);
        min-height: 100vh;
    }

    /* Text Colors */
    .text-purple {
        color: var(--primary-purple) !important;
    }

    .bg-purple {
        background: var(--primary-purple) !important;
    }

    .bg-soft-purple {
        background: var(--primary-purple-soft) !important;
    }

    .bg-gradient-purple {
        background: var(--gradient-purple) !important;
    }

    /* Dashboard Header */
    .dashboard-header {
        background: white;
        border-radius: 20px;
        padding: 1.5rem 2rem;
        box-shadow: 0 8px 25px rgba(140, 93, 209, 0.08);
        border: 1px solid rgba(140, 93, 209, 0.1);
    }

    .teacher-profile-card {
        background: var(--primary-purple-light);
        padding: 1rem 1.5rem;
        border-radius: 15px;
        border: 1px solid rgba(140, 93, 209, 0.2);
    }

    .profile-avatar {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 600;
        color: white;
    }

    /* Modern Cards */
    .modern-card {
        background: white;
        border-radius: 20px;
        padding: 1.5rem;
        box-shadow: 0 8px 25px rgba(140, 93, 209, 0.08);
        border: 1px solid rgba(140, 93, 209, 0.1);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .modern-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(140, 93, 209, 0.15);
        }

    .stat-card {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .stat-icon-wrapper {
        width: 70px;
        height: 70px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
    }

    .stat-content {
        flex: 1;
    }

    .stat-label {
        font-size: 0.9rem;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .stat-value {
        font-size: 2.2rem;
        font-weight: 700;
        color: #2d3748;
        margin: 0;
        line-height: 1.2;
    }

    .stat-progress {
        margin-top: 0.5rem;
    }

    /* Glass Card */
    .glass-card {
        background: white;
        border-radius: 20px;
        box-shadow: 0 8px 30px rgba(140, 93, 209, 0.08);
        border: 1px solid rgba(140, 93, 209, 0.1);
        overflow: hidden;
        transition: all 0.3s ease;
    }

        .glass-card:hover {
            box-shadow: 0 12px 40px rgba(140, 93, 209, 0.12);
        }

    /* Modern Table */
    .modern-table {
        margin-bottom: 0;
    }

        .modern-table thead th {
            background: var(--primary-purple-light);
            color: var(--primary-purple);
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid var(--primary-purple);
            padding: 1rem;
        }

        .modern-table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-bottom: 1px solid rgba(140, 93, 209, 0.1);
        }

        .modern-table tbody tr:hover {
            background: rgba(140, 93, 209, 0.02);
        }

    /* Avatar */
    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        text-transform: uppercase;
    }

    .project-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
    }

    /* Status Badges */
    .status-badge {
        padding: 0.35rem 1rem;
        border-radius: 50px;
        font-size: 0.8rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
    }

        .status-badge.active {
            background: rgba(40, 167, 69, 0.1);
            color: #28a745;
        }

        .status-badge.completed {
            background: rgba(40, 167, 69, 0.1);
            color: #28a745;
        }

        .status-badge.in-progress {
            background: rgba(140, 93, 209, 0.1);
            color: var(--primary-purple);
        }

        .status-badge.pending {
            background: rgba(255, 193, 7, 0.1);
            color: #ffc107;
        }

    /* Buttons */
    .btn-outline-purple {
