@model ProjectManagementSystem.DBModels.TeacherDashboardViewModel
@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Teacher Dashboard";
    ViewData["PageTitle"] = "Teacher Overview";
    ViewData["Breadcrumb"] = "Home / Teacher Dashboard";
}

<!-- Modern Teacher Dashboard Design -->
<div class="dashboard-container">

    <!-- Header Section with Gradient -->
    <div class="dashboard-header mb-4">
        <div class="row align-items-center">
            <div class="col-md-8">
                <div class="welcome-section">
                    <h1 class="display-6 fw-bold text-purple">
                        <i class="bi bi-person-workspace me-2"></i>Teacher Dashboard
                    </h1>
                   @*  <div class="welcome-message mt-2">
                        <span class="badge bg-soft-purple px-3 py-2">
                            <i class="bi bi-calendar-check me-2"></i>
                            @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
                        </span>
                    </div> *@
                </div>
            </div>
            <div class="col-md-4">
                <div class="teacher-profile-card float-md-end">
                    <div class="d-flex align-items-center">
                        <div class="profile-avatar bg-gradient-purple">
                            @ViewBag.FullName?.Substring(0, 1)
                        </div>
                        <div class="ms-3">
                            <h6 class="mb-0 fw-bold">Welcome back,</h6>
                            <p class="mb-0 text-purple fw-semibold">@ViewBag.FullName</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats Banner -->
    <div class="stats-banner mb-4">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="stat-card modern-card h-100">
                    <div class="stat-icon-wrapper bg-soft-purple">
                        <i class="bi bi-people-fill text-purple"></i>
                    </div>
                    <div class="stat-content">
                        <span class="stat-label">Assigned Students</span>
                        <h3 class="stat-value">@Model.TotalStudents</h3>
                       @*  <div class="stat-progress">
                            <div class="progress" style="height: 5px;">
                                <div class="progress-bar bg-purple" style="width: 75%"></div>
                            </div>
                            <small class="text-muted">75% of capacity</small>
                        </div> *@
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card modern-card h-100">
                    <div class="stat-icon-wrapper bg-soft-purple">
                        <i class="bbi bi-arrow-up-short text-purple"></i>
                    </div>
                    <div class="stat-content">
                        <span class="stat-label">Projects Under Supervision</span>
                        <h3 class="stat-value">@Model.TotalProjects</h3>
                        @* <div class="stat-progress">
                            <div class="progress" style="height: 5px;">
                                <div class="progress-bar bg-purple" style="width: 60%"></div>
                            </div>
                            <small class="text-muted">60% active</small>
                        </div> *@
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card modern-card h-100">
                    <div class="stat-icon-wrapper bg-soft-purple">
                        <i class="bi bi-building-fill text-purple"></i>
                    </div>
                    <div class="stat-content">
                        <span class="stat-label">Companies Assigned</span>
                        <h3 class="stat-value">@Model.TotalCompanies</h3>
                        @* <div class="stat-progress">
                            <div class="progress" style="height: 5px;">
                                <div class="progress-bar bg-purple" style="width: 45%"></div>
                            </div>
                            <small class="text-muted">45% partnered</small>
                        </div> *@
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Dashboard Content -->
    <div class="row g-4">
        <!-- Left Column - Projects & Students -->
        <div class="col-lg-8">
            <!-- Recent Projects Section -->
            <div class="glass-card mb-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-folder-symlink-fill text-purple me-2"></i>
                            Recent Projects Under Supervision
                        </h5>
                        <a asp-controller="ProjectApproval" asp-action="Index" class="btn btn-sm btn-outline-purple">
                            View All <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table modern-table mb-0">
                            <thead>
                                <tr>
                                    <th>Project</th>
                                    <th>Project Member</th>
                                    <th>Company</th>
                                    @* <th>Progress</th> *@
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentProjects != null && Model.RecentProjects.Count > 0)
                                {
                                    foreach (var project in Model.RecentProjects)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    @* <div class="project-icon bg-soft-purple me-2">
                                                        <i class="bi bi-folder-text text-purple"></i>
                                                    </div> *@
                                                    <div>
                                                        <h6 class="mb-0">@project.Title</h6>
                                                        <small class="text-muted">ID: @project.Id</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark">
                                                    @project.MembersCount Students
                                                </span>
                                            </td>
                                           @*  <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-circle bg-soft-purple text-purple me-2">
                                                        @project.StudentName?.Substring(0, 1)
                                                    </div>
                                                    <span>@project.StudentName</span>
                                                </div>
                                            </td> *@
                                            <td>
                                                <span class="badge bg-soft-purple">@project.CompanyName</span>
                                            </td>
                                            @* <td>
                                                <div class="progress-info">
                                                    <div class="progress" style="height: 6px; width: 100px;">
                                                        <div class="progress-bar bg-purple" style="width: @project.Progress%"></div>
                                                    </div>
                                                    <small class="ms-2">@project.Progress%</small>
                                                </div>
                                            </td> *@
                                            <td>
                                                @if (project.Status == "Completed")
                                                {
                                                    <span class="status-badge completed">
                                                        <i class="bi bi-check-circle-fill me-1"></i>Completed
                                                    </span>
                                                }
                                                else if (project.Status == "In Progress")
                                                {
                                                    <span class="status-badge in-progress">
                                                        <i class="bi bi-arrow-repeat me-1"></i>In Progress
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="status-badge pending">
                                                        <i class="bi bi-clock-fill me-1"></i>Pending
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                <div class="action-buttons">
                                                    <a asp-controller="ProjectApproval"
                                                       asp-action="Details"
                                                       asp-route-id="@project.Id"
                                                       class="btn btn-sm btn-icon text-purple"
                                                       title="View">
                                                        <i class="bi bi-eye-fill"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4">
                                            <div class="empty-state">
                                                <i class="bi bi-folder-x display-4 text-muted"></i>
                                                <p class="text-muted mt-2">No projects found</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Assigned Students Section -->
            <div class="glass-card">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="bi bi-people-fill text-purple me-2"></i>
                            My Assigned Students
                        </h5>
                        <div class="header-actions">
                            <span class="badge bg-soft-purple me-2">@Model.TotalStudents Total</span>
                            <a asp-controller ="Student" asp-action="Index" class="btn btn-sm btn-outline-purple">
                                View All <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table modern-table mb-0">
                            <thead>
                                <tr>
                                    <th>Student</th>
                                    <th>Email</th>
                                    <th>Roll Number</th>
                                    <th>Academic Year</th>
                                    <th>Company</th>
                                    @* <th>Last Active</th> *@
                                    @* <th>Status</th> *@
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.AssignedStudents != null && Model.AssignedStudents.Count > 0)
                                {
                                    foreach (var student in Model.AssignedStudents)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                   @*  <div class="avatar-circle bg-gradient-purple text-white me-2">
                                                        @student.Name?.Substring(0, 1)
                                                    </div> *@
                                                    <div>
                                                        <h6 class="mb-0">@student.Name</h6>
                                                        <small class="text-muted">ID: @student.Id</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>@student.Email</td>
                                            <td>@student.RollNumber</td>
                                            <td>@student.YearRange</td>
                                            @* <td>
                                                <span class="badge bg-soft-purple">@student.ProjectTitle</span>
                                            </td> *@
                                            <td>
                                                <span class="badge bg-light text-dark">@student.CompanyName</span>
                                            </td>
                                            @* <td>
                                                <small class="text-muted">
                                                    <i class="bi bi-clock-history me-1"></i>
                                                    @student.LastActive
                                                </small>
                                            </td> *@
                                            @* <td>
                                                <span class="status-badge active">
                                                    <i class="bi bi-check-circle-fill me-1"></i>Active
                                                </span>
                                            </td> *@
                                            <td>
                                                <div class="action-buttons">
                                                    <a asp-controller="Student"
                                                       asp-action="Detail"
                                                       asp-route-id="@student.Id"
                                                       class="btn btn-sm btn-icon text-purple"
                                                       title="View">
                                                        <i class="bi bi-eye-fill"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4">
                                            <div class="empty-state">
                                                <i class="bi bi-person-x display-4 text-muted"></i>
                                                <p class="text-muted mt-2">No students assigned</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column - Stats & Activities -->
        <div class="col-lg-4">
            <!-- Performance Overview Card -->
            <div class="glass-card mb-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="mb-0">
                        <i class="bi bi-graph-up-arrow text-purple me-2"></i>
                        Performance Overview
                    </h5>
                </div>
                <div class="card-body">
                    <div class="performance-chart mb-3">
                        <canvas id="performanceChart" height="200"></canvas>
                    </div>
                    <div class="performance-stats">
                        <div class="stat-row d-flex justify-content-between mb-2">
                            <span class="text-muted">Completion Rate</span>
                            <span class="fw-bold text-purple">78%</span>
                        </div>
                        <div class="stat-row d-flex justify-content-between mb-2">
                            <span class="text-muted">On-time Submissions</span>
                            <span class="fw-bold text-success">85%</span>
                        </div>
                        <div class="stat-row d-flex justify-content-between">
                            <span class="text-muted">Average Grade</span>
                            <span class="fw-bold" style="color: #8c5dd1;">A-</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Upcoming Deadlines -->
            @* <div class="glass-card mb-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="mb-0">
                        <i class="bi bi-calendar-event-fill text-purple me-2"></i>
                        Upcoming Deadlines
                    </h5>
                </div>
                <div class="card-body">
                    @if (ViewBag.Deadlines != null && ViewBag.Deadlines.Count > 0)
                    {
                        <div class="deadline-list">
                            @foreach (var deadline in ViewBag.Deadlines)
                            {
                                <div class="deadline-item">
                                    <div class="deadline-date">
                                        <span class="day">@deadline.Day</span>
                                        <span class="month">@deadline.Month</span>
                                    </div>
                                    <div class="deadline-info">
                                        <h6 class="mb-1">@deadline.Title</h6>
                                        <small class="text-muted">
                                            <i class="bi bi-person me-1"></i>@deadline.StudentName
                                        </small>
                                    </div>
                                    <div class="deadline-badge">
                                        <span class="badge bg-soft-purple">@deadline.DaysLeft days left</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state py-3">
                            <i class="bi bi-calendar-check display-4 text-muted"></i>
                            <p class="text-muted mt-2">No upcoming deadlines</p>
                        </div>
                    }
                </div>
            </div> *@

            <!-- Companies Assigned -->
            <div class="glass-card mb-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="mb-0">
                        <i class="bi bi-building-fill text-purple me-2"></i>
                        Partner Companies
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Companies != null && Model.Companies.Count > 0)
                    {
                        <div class="company-list">
                            @foreach (var company in Model.Companies)
                            {
                                <div class="company-item">
                                    <div class="company-logo bg-soft-purple">
                                        <i class="bi bi-building text-purple"></i>
                                    </div>
                                    <div class="company-info">
                                        <h6 class="mb-0">@company.Name</h6>
                                        <small class="text-muted">@company.ProjectsCount projects</small>
                                    </div>
                                    <div class="company-status">
                                        <span class="badge bg-soft-purple">@company.StudentsCount students</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state py-3">
                            <i class="bi bi-building display-4 text-muted"></i>
                            <p class="text-muted mt-2">No companies assigned</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Quick Actions -->
           @*  <div class="glass-card">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="mb-0">
                        <i class="bi bi-lightning-charge-fill text-purple me-2"></i>
