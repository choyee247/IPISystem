            line-height: 1;
        }

        .deadline-date .month {
            font-size: 0.7rem;
            text-transform: uppercase;
            color: #6c757d;
        }

    .deadline-info {
        flex: 1;
    }

    /* Company List */
    .company-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .company-item {
        display: flex;
        align-items: center;
        gap: 1rem;
