@model IEnumerable<ProjectManagementSystem.DBModels.Teacher>
@{
    Layout = "_TeacherLayout";
}
<style>
    .btn-purple {
        background-color: #8C5DD1 !important; /* Purple background */
        color: #fff !important; /* White text */
        border: none;
        transition: background-color 0.3s ease, transform 0.2s ease;
    }

        .btn-purple:hover {
            background-color: #6b3fa0 !important; /* Darker purple on hover */
            color: #fff !important;
            transform: translateY(-2px);
        }

    .avatar-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #8C5DD1, #8C5DD1);
        color: #fff;
        font-weight: 600;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 1rem;
    }

    .table-row:hover {
        background-color: #f8f9fa;
        transition: background-color 0.2s ease-in-out;
    }

    .table th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        color: #6c757d;
    }

    .table td {
        vertical-align: middle;
        padding-top: 0.75rem;
        padding-bottom: 0.75rem;
    }
</style>
<script src="~/Resources/bootstrap538/js/bootstrap.bundle.min.js"></script>
<link href="~/Resources/bootstrap538/css/bootstrap.min.css" rel="stylesheet" />
<script>
    // Search Filter
    document.getElementById("searchInput").addEventListener("keyup", function () {
        let value = this.value.toLowerCase();
        document.querySelectorAll("#teacherTable tbody tr").forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(value) ? "" : "none";
        });
    });

    // Single Modal Setup
    var deleteModal = document.getElementById('deleteModal');
    deleteModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        var teacherId = button.getAttribute('data-id');

        // Update modal text
        document.getElementById('deleteTeacherId').textContent = teacherId;

        // Update form action dynamically
        var form = document.getElementById('deleteForm');
        form.action = '/Teacher/Delete/' + teacherId; // adjust controller route if needed
    });
</script>

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Teacher Management</h2>
        <a asp-action="Create"
           class="btn rounded-pill px-4 shadow-sm"
           style="background-color: #8C5DD1; color: #fff; border: none;">
            <i class="bi bi-person-plus me-1"></i> Add Teacher
        </a>

    </div>
   
    <!-- Table Card -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive">
            <table class="table align-middle mb-0" id="teacherTable">
                <thead class="bg-light">
                    <tr>
                        <th>Teacher</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Created Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var t in Model)
                    {
                        <tr class="table-row">
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-circle">
                                        @t.FullName?.Substring(0, 1)
                                    </div>
                                    <div>
                                        <div class="fw-semibold">@t.FullName</div>
                                        <small class="text-muted">ID: @t.Id</small>
                                    </div>
                                </div>
                            </td>

                            <td>@t.Email</td>

                            <td>
                                @if (t.Role == "Admin")
                                {
                                    <span class="badge rounded-pill bg-danger-subtle text-danger px-3 py-2">Admin</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-success-subtle text-success px-3 py-2">Teacher</span>
                                }
                            </td>

                            <td>@t.CreatedDate?.ToString("dd MMM yyyy")</td>

                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@t.Id"
                                   class="btn btn-outline-warning btn-sm rounded-circle me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <!-- Delete Button (opens single modal) -->
                                <button type="button"
                                        class="btn btn-outline-danger btn-sm rounded-circle"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal"
                                        data-id="@t.Id">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- 🔴 Single Reusable Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                Are you sure you want to delete teacher with ID: <strong id="deleteTeacherId"></strong>?
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>

        </div>
    </div>
</div>



