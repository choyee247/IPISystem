@model ProjectManagementSystem.DBModels.Teacher
@{
    Layout = "_TeacherLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <!-- Card Wrapper -->
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header text-white text-center rounded-top-4" style="background-color: #8C5DD1;">
                    <h3 class="mb-0 fw-bold">Add New Teacher</h3>
                </div>
                <div class="card-body p-5">

                    <form asp-action="Create" asp-controller="Teacher" method="post" novalidate>
                        @Html.AntiForgeryToken()

                        <!-- Full Name -->
                        <div class="form-floating mb-4">
                            <input asp-for="FullName" class="form-control" placeholder="Full Name" />
                            <label asp-for="FullName">Full Name</label>
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <!-- Email -->
                        <div class="form-floating mb-4">
                            <input asp-for="Email" class="form-control" placeholder="Email" />
                            <label asp-for="Email">Email</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- Password -->
                        <div class="form-floating mb-4">
                            <input asp-for="PasswordHash" type="password" class="form-control" placeholder="Password" />
                            <label asp-for="PasswordHash">Password</label>
                            <span asp-validation-for="PasswordHash" class="text-danger small"></span>
                        </div>

                        <!-- Role -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">Role</label>
                            <select asp-for="Role" class="form-select form-select-lg rounded-3">
                                <option value="">-- Select Role --</option>
                                <option value="Teacher">Teacher</option>
                                <option value="Admin">Admin</option>
                            </select>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" asp-controller="Teacher" class="btn btn-light btn-lg rounded-pill px-4">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-lg rounded-pill px-5" style="background-color: #8C5DD1; color: #fff; border: none;">
                                <i class="bi bi-save me-1"></i> Save Teacher
                            </button>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

<!-- Optional Styles -->
<style>
    .form-label {
        font-size: 0.9rem;
        color: #374151;
    }

    .form-control::placeholder {
        color: #9ca3af;
    }

    .form-select {
        cursor: pointer;
    }

    .btn:hover {
        background-color: #6b3fa0 !important;
        color: #fff !important;
    }
</style>
