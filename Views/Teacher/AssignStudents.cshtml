@model ProjectManagementSystem.Models.AssignStudentsViewModel
@{
    Layout = "_TeacherLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <div class="card shadow-lg border-0 rounded-4" style="border-top: 5px solid #8C5DD1;">
                <div class="card-header text-white text-center rounded-top-4" style="background-color: #8C5DD1;">
                    <h3 class="mb-0 fw-bold">Assign Students to @Model.TeacherName</h3>
                </div>
                <div class="card-body p-5">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="AssignStudents" asp-controller="Teacher" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="TeacherId" />

                        <table class="table table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 50px;">Select</th>
                                    <th>Student Name</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.Students.Count; i++)
                                {
                                    <tr>
                                        <td class="text-center">
                                            <input type="checkbox"
                                                   name="SelectedStudentIds"
                                                   value="@Model.Students[i].Value"
                                            @(Model.Students[i].Selected ? "checked" : "") />
                                        </td>
                                        <td>@Model.Students[i].Text</td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" asp-controller="Teacher"
                               class="btn btn-outline-secondary btn-lg rounded-pill px-4">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-purple btn-lg rounded-pill px-5">
                                Assign Students
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .btn-purple {
        background-color: #8C5DD1;
        color: #fff;
        border: none;
        transition: background-color 0.3s ease;
    }

        .btn-purple:hover {
            background-color: #6b3fa0;
            color: #fff;
        }

    table th, table td {
        vertical-align: middle;
    }
</style>
