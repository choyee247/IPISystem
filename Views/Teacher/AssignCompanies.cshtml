@model AssignCompaniesViewModel
@{
    ViewData["Title"] = "Assign Companies";
    Layout = "~/Views/Shared/_TeacherLayout.cshtml";
}

<h3>Assign Companies to @Model.TeacherName</h3>

<form asp-action="AssignCompanies" method="post">
    <input type="hidden" asp-for="TeacherId" />

    <div class="mb-3">
        <label class="form-label">Companies</label>
        @foreach (var c in Model.Companies)
        {
            <div class="form-check">
                <input class="form-check-input"
                       type="checkbox"
                       name="SelectedCompanyIds"
                       value="@c.Value"
                       checked="@c.Selected" />
                <label class="form-check-label">@c.Text</label>
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Details" asp-route-id="@Model.TeacherId" class="btn btn-secondary">Cancel</a>
</form>
