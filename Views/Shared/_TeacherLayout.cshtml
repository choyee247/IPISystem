@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    Layout = null;
    // var fullName = ViewBag.FullName ?? "Teacher";
    // var userRole = HttpContextAccessor.HttpContext.Session.GetString("UserRole");
    var userRole = HttpContextAccessor.HttpContext.Session.GetString("UserRole") ?? "Teacher";
    var fullName = HttpContextAccessor.HttpContext.Session.GetString("UserName") ?? "Teacher";
    //var title = userRole.Equals("Admin", StringComparison.OrdinalIgnoreCase) ? "Admin Notifications" : "My Notifications";
}

@{
    //var userRole = Context.Session.GetString("UserRole") ?? "Guest";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Internship Project Information System</title>
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <script src="~/Resources/Jquery/jquery-validation-master/js/jquery-3.7.1.min.js"></script>
    <script src="~/Resources/chart/chart.umd.min.js"></script>
    <script src="~/Resources/Jquery/jquery-validation-master/js/jquery.validate.min.js"></script>
    <script src="~/Resources/Jquery/jquery-validation-unobtrusive-main/src/jquery.validate.unobtrusive.js"></script>
    <link href="~/Resources/boxicons-master/css/boxicons.min.css" rel="stylesheet" />
    <link href="~/Resources/fontawesome-free-6.7.2-web/css/all.min.css" rel="stylesheet" />
    <link href="~/Resources/bootstrap538/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Resources/icons-main/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/approve.css" />
    <link rel="stylesheet" href="~/Resources/sweetalert/sweetalert2.min.css" />
    <script src="~/Resources/sweetalert/sweetalert2.all.min.js"></script>

    @RenderSection("Styles", required: false)

</head>
<body>
    <div class="app">
        <aside class="sidebar" id="sidebar">
            <div class="brand">
                <img src="~/images/logo.png" alt="Company Logo" class="brand-logo" />
                @if (userRole == "Admin")
                {
                    <span class="brand-name">Admin Panel</span>
                }
                else
                {
                    <span class="brand-name">Teacher Panel</span>
                }
            </div>
            <ul class="menu">
                <li class="menu-item @(
    (userRole == "Admin" && currentController == "Admin" && currentAction == "Dashboard") ||
    (userRole == "Teacher" && currentController == "Teacher" && currentAction == "Dashboard")
    ? "active" : "")">

                    @if (userRole == "Admin")
                    {
                        <a asp-controller="Admin" asp-action="Dashboard">
                            <i class="bx bx-grid-alt"></i>
                            <span class="menu-text">Dashboard</span>
                        </a>
                    }
                    else if (userRole == "Teacher")
                    {
                        <a asp-controller="Teacher" asp-action="Dashboard">
                            <i class="bx bx-grid-alt"></i>
                            <span class="menu-text">Dashboard</span>
                        </a>
                    }
                    else
                    {
                        <!-- Guest or unknown role -->
                        <a href="#">
                            <i class="bx bx-grid-alt"></i>
                            <span class="menu-text">Dashboard</span>
                        </a>
                    }
                </li>


                <li class="menu-item has-submenu" id="managementMenu">
                    <div class="submenu-header">
                        <i class="bx bx-briefcase"></i>
                        <span class="menu-text">Management</span>
                        <i class="bx bx-chevron-right submenu-toggle"></i>
                    </div>
                    <ul class="submenu">
                        @if (userRole == "Admin")
                        {
                            <li class="submenu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Teacher" ? "active" : "")">
                                <a asp-controller="Teacher" asp-action="Index">Teacher Management</a>
                            </li>
                            <li class="submenu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DownloadRequest" ? "active" : "")">
                                <a asp-controller="Admin" asp-action="DownloadRequests">Download Requests</a>
                            </li>
                        }
                        <li class="submenu-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Student" ? "active" : "")">
                            <a asp-area="" asp-controller="Student" asp-action="Index">Student Management</a>
                        </li>
                        <li class="submenu-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "StudentManagement" ? "active" : "")">
                            <a asp-area="" asp-controller="Email" asp-action="Index">Email Management</a>
                        </li>
                        <li class="submenu-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Company" ? "active" : "")">
                            <a asp-area="" asp-controller="Company" asp-action="Index">Company</a>
                        </li>
                    </ul>
                </li>
                <!-- Announcement Menu -->
                <li class="menu-item has-submenu" id="announcementMenu">
                    <div class="submenu-header">
                        <i class="bi bi-megaphone-fill"></i>

                        <span class="menu-text">Announcements</span>
                        <i class="bx bx-chevron-right submenu-toggle"></i>
                    </div>
                    <ul class="submenu">
                        <li class="submenu-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                            <a asp-controller="Announcement" asp-action="Index">All Announcements</a>
                        </li>
                        <li class="submenu-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Create" ? "active" : "")">
                            <a asp-controller="Announcement" asp-action="Create">Create Announcement</a>
                        </li>
                    </ul>
                </li>


                <li class="menu-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "SubmittedProjects" ? "active" : "")">
                    <a asp-area="" asp-controller="ProjectApproval" asp-action="Index">
                        <i class="bx bx-folder-open"></i>
                        <span class="menu-text">Project Approval</span>
                    </a>
                </li>

                <li class="menu-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")">
                    <a asp-area="" asp-controller="Admin" asp-action="MyProfile">
                        <i class="bx bx-user"></i>
                        <span class="menu-text">My Profile</span>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "TeacherNotifications" ? "active" : "")">
                    <a asp-area="" asp-controller="Notifications" asp-action="IndexTeacher">
                        <i class="bx bx-bell"></i>
                        <span class="menu-text">Notifications</span>
                    </a>
                </li>

                <li class="menu-item">
                    <a href="#" onclick="return confirmLogout();">
                        <i class="bx bx-log-out"></i>
                        <span class="menu-text">Logout</span>
                    </a>

                    <form id="logoutForm" asp-controller="Admin" asp-action="Logout" method="post" style="display: none;"></form>
                </li>
            </ul>
            <div class="toggle-collapse" id="collapseBtn">
                <i class="bx bx-chevrons-left"></i>
            </div>
        </aside>

        <div class="main">
            <header class="navbar">
                <div class="nav-left">
                    <i class="bx bx-menu toggle-btn" id="menuBtn"></i>
                    <div class="date-time" id="dateTimeDisplay"></div>
                </div>

                <div class="nav-icons-container">
                    <!-- Notification Bell -->
                    <div class="cute-notifications">
                        <a class="cute-bell" href="#" id="notificationDropdown">
                            <svg class="bell-icon" viewBox="0 0 24 24">
                                <path fill="#8C5DD1" d="M12,22A2,2 0 0,0 14,20H10A2,2 0 0,0 12,22M18,16V11C18,7.93 16.36,5.36 13.5,4.68V4A1.5,1.5 0 0,0 12,2.5A1.5,1.5 0 0,0 10.5,4V4.68C7.63,5.36 6,7.92 6,11V16L4,18V19H20V18L18,16Z" />
                                <circle class="pulse" fill="#FF6B6B" cx="18" cy="5" r="3.2" />
                            </svg>

                            <!-- ✅ Dynamic Count -->
                            <span class="cute-badge">
                                @await Component.InvokeAsync(typeof(ProjectManagementSystem.ViewComponents.NotificationCountViewComponent))
                            </span>
                        </a>

                        <!-- Dropdown -->
                        <div class="cute-notification-box">
                            <div class="notification-header">
                                <div class="header-left">
                                    <h6 class="cute-title">My Notifications</h6>
                                </div>
                                <button class="mark-all-read" id="markAllRead"></button>
                            </div>

                            <div class="notification-list">
                                @await Component.InvokeAsync("Notification")
                            </div>
                        </div>
                    </div>
                    
                    <div class="profile-container">
                        <span class="avatar" style="background-color:#8c5dd1; color:white; padding:5px 10px; border-radius:50%;">
                            @HttpContextAccessor.HttpContext.Session.GetString("UserInitial")
                        </span>
                        <span class="profile-name">
                            @HttpContextAccessor.HttpContext.Session.GetString("UserName")
                        </span>
                    </div>

                </div>
            </header>

            <main class="content">
                @RenderBody()
            </main>
        </div>
    </div>

    @*  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script> *@
    <script src="~/Resources/Jquery/jquery-validation-master/js/jquery-3.7.1.min.js"></script>
    <script src="~/Resources/Jquery/jquery-validation-master/js/jquery.validate.min.js"></script>
    <script src="~/Resources/Jquery/jquery-validation-unobtrusive-main/src/jquery.validate.unobtrusive.js"></script>
    <script src="~/Resources/bootstrap538/js/bootstrap.bundle.min.js"></script>
    <script src="~/Resources/bootstrap538/js/bootstrap.min.js"></script>
    <script src="~/Resources/chart/chart.umd.min.js"></script>
  
    <script>
                function loadTeacherUnreadCount() {
            fetch('/Notifications/GetTeacherUnreadCount')
                .then(response => response.json())
                .then(count => {
                    let badge = document.getElementById("notificationBadge");

                    if (count > 0) {
                        badge.innerText = count;
                        badge.style.display = "flex";
                    } else {
                        badge.innerText = "";
                        badge.style.display = "none";
                    }
                })
                .catch(err => console.error(err));
        }

        // Page load
        loadTeacherUnreadCount();

        // Refresh every 10 seconds
        setInterval(loadTeacherUnreadCount, 10000);

        //              // ---------- TEACHER UNREAD NOTIFICATION ----------
        // function loadTeacherUnreadCount(){
        //     const badge = document.getElementById("notificationBadge");
        //     if(!badge) return;

        //     fetch('@Url.Action("GetTeacherUnreadCount", "Notifications")')
        //     .then(res=>res.json())
        //     .then(count=>{
        //         badge.innerText = count>0 ? count : "";
        //         badge.style.display = count>0 ? "flex" : "none";
        //     })
        //     .catch(err=>console.error(err));
        // /* ================= TEACHER NOTIFICATION COUNT ================= */
        // function loadTeacherUnreadCount() {
        //     const badge = document.getElementById("notificationBadge");
        //     if (!badge) return;

        //     fetch('/Notifications/GetTeacherUnreadCount')
        //         .then(r => r.json())
        //         .then(count => {
        //             if (count > 0) {
        //                 badge.innerText = count;
        //                 badge.style.display = "flex";
        //             } else {
        //                 badge.innerText = "";
        //                 badge.style.display = "none";
        //             }
        //         })
        //         .catch(console.error);
        // }
        // loadTeacherUnreadCount();
        // setInterval(loadTeacherUnreadCount,10000);
        // setInterval(loadTeacherUnreadCount, 10000);


        /* ================= LOGOUT ================= */
        function confirmLogout() {
            if (confirm("Do you really want to log out?")) {
                document.getElementById('logoutForm')?.submit();
            }
            return false;
        }


        /* ================= DOM READY ================= */
        document.addEventListener("DOMContentLoaded", function () {

            /* ---------- SIDEBAR & MENU ---------- */
            const sidebar = document.getElementById("sidebar");
            const collapseBtn = document.getElementById("collapseBtn");
            const menuBtn = document.getElementById("menuBtn");
            const menuLinks = document.querySelectorAll(".menu-item > a");
            const submenuHeaders = document.querySelectorAll(".submenu-header");

            // Sidebar toggle
            [collapseBtn, menuBtn].forEach(btn => {
                if (btn) {
                    btn.addEventListener("click", () => {
                        sidebar.classList.toggle("collapsed");
                    });
                }
            });

            // Submenu toggle
            submenuHeaders.forEach(header => {
                header.addEventListener("click", () => {
                    const parent = header.closest(".has-submenu");

                    if (!sidebar.classList.contains("collapsed")) {
                        document.querySelectorAll(".has-submenu.open").forEach(item => {
                            if (item !== parent) item.classList.remove("open");
                        });
                    }

                    parent.classList.toggle("open");
                });
            });

            // Active menu (visual only, no conflict)
            menuLinks.forEach(link => {
                link.addEventListener("click", function () {
                    document.querySelectorAll(".menu-item")
                        .forEach(item => item.classList.remove("active"));
                    this.closest(".menu-item")?.classList.add("active");
                });
            });


            /* ---------- NOTIFICATIONS ---------- */
            const notificationDropdown = document.getElementById("notificationDropdown");
            const notificationBox = document.querySelector(".cute-notifications");
            const notificationBadge = document.getElementById("notificationBadge");
            const markAllBtn = document.getElementById("markAllRead");

            // Toggle dropdown
            if (notificationDropdown && notificationBox) {
                notificationDropdown.addEventListener("click", function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    notificationBox.classList.toggle("active");
                });

                document.addEventListener("click", function (e) {
                    if (!notificationBox.contains(e.target)) {
                        notificationBox.classList.remove("active");
                    }
                });
            }

            // Notification item click
            document.querySelectorAll(".notification-item").forEach(item => {
                item.addEventListener("click", function (e) {
                    e.preventDefault();

                    const id = this.dataset.notificationId;
                    const url = this.href;

                    if (!id) {
                        window.location.href = url;
                        return;
                    }

                    fetch('/Notifications/MarkAsRead', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken':
                                document.querySelector('input[name="__RequestVerificationToken"]')?.value
                        },
                        body: JSON.stringify({ id })
                    })
                    .then(r => r.json())
                    .then(res => {
                        if (res.success && notificationBadge) {
                            notificationBadge.textContent = res.unreadCount;
                        }
                        window.location.href = url;
                    })
                    .catch(console.error);
                });
            });

            // Mark all as read (SAFE)
            if (markAllBtn) {
                markAllBtn.addEventListener("click", function () {
                    fetch('/Notifications/MarkAllAsRead', { method: 'POST' })
                        .then(() => {
                            document.querySelectorAll(".notification-item")
                                .forEach(i => i.classList.remove("new-notification"));
                            if (notificationBadge) notificationBadge.textContent = "0";
                        })
                        .catch(console.error);
                });
            }

            // Refresh notification count
            // setInterval(() => {
            //     if (!notificationBadge) return;
            //     fetch('/Notifications/GetNotificationCount')
            //         .then(r => r.json())
            //         .then(count => notificationBadge.textContent = count)
            //         .catch(console.error);
            // }, 60000);


            /* ---------- TIME DISPLAY ---------- */
            function updateTime() {
                const el = document.getElementById("dateTimeDisplay");
                if (!el) return;

                el.textContent = new Date().toLocaleString("en-US", {
                    weekday: "short",
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                    hour: "2-digit",
                    minute: "2-digit"
                });
            }

            updateTime();
            setInterval(updateTime, 1000);
        });


    </script>

    <style>
        /* In site.css or approve.css */
        .menu-item.active > a,
        .submenu-item.active > a {
            text-decoration: none !important;
        }

        .menu-item.has-submenu .submenu-header.active {
            text-decoration: none !important;
        }

        .menu a,
        .submenu a {
            text-decoration: none !important;
        }

        .menu-item.active > a,
        .submenu-item.active > a {
            text-decoration: none !important;
            background: rgba(140,93,209,0.15);
            border-left: 4px solid #8C5DD1;
        }


    </style>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html> 