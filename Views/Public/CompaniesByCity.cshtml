@model X.PagedList.IPagedList<ProjectManagementSystem.DBModels.CompanyViewModel>

@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Internship Companies in " + ViewBag.CityName;
    Layout = "~/Views/Shared/_PublicLayout.cshtml";

    var cityName = ViewBag.CityName as string ?? "City";
    var cityId = ViewBag.CityId as int? ?? 0;
    var totalCompanies = ViewBag.TotalCompanies as int? ?? 0;
    var totalStudents = ViewBag.TotalStudents as int? ?? 0;
}

<style>
    .card {
        border: 1px solid #8c5dd1;
        background-color: #e4eefd;
        transition: 0.3s ease-in-out;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 18px rgba(0,0,0,0.15);
        }

    .card-title {
        color: #8c5dd1;
        font-weight: bold;
    }

    .student-badge {
        background-color: #8c5dd1;
        color: white;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.85rem;
        margin-bottom: 0.5rem;
        display: inline-block;
    }

    .btn-secondary {
        background-color: #8c5dd1;
        border-color: #8c5dd1;
        color: white;
    }

        .btn-secondary:hover {
            background-color: #7b4fc7;
            border-color: #7b4fc7;
            color: white;
        }

    .pagination .page-item.active .page-link {
        background-color: #8c5dd1;
        border-color: #8c5dd1;
        color: #fff;
    }
</style>

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <h2 class="mb-0">Internship Companies in @cityName</h2>

    <div class="student-badge" title="Total Students and Companies">
        @totalCompanies Companies – @totalStudents Students
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var company in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(company.ImageFileName))
                    {
                        <img src="@Url.Content("~/images/companies/" + company.ImageFileName)"
                             class="card-img-top"
                             alt="@company.CompanyName"
                             style="height:180px; object-fit:cover;" />
                    }
                    else
                    {
                        <img src="~/images/placeholder-company.png"
                             class="card-img-top"
                             alt="No image"
                             style="height:180px; object-fit:cover;" />
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@company.CompanyName</h5>

                        <span class="student-badge">@company.StudentCount Students</span>

                        @if (!string.IsNullOrWhiteSpace(company.Address))
                        {
                            <p class="mb-1"><strong>Address:</strong> @company.Address</p>
                        }

                        @if (!string.IsNullOrWhiteSpace(company.Contact))
                        {
                            <p class="mb-1"><strong>Contact:</strong> @company.Contact</p>
                        }

                        @if (!string.IsNullOrWhiteSpace(company.Description))
                        {
                            <p class="card-text mt-2">@company.Description</p>
                        }

                        <a asp-action="CompaniesByCity"
                           asp-route-id="@company.Company_pkId"
                           class="btn btn-primary mt-auto d-none">
                            <!-- Placeholder for possible future action -->
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="d-flex justify-content-center mt-4">
        @Html.PagedListPager(Model, page => Url.Action("CompaniesByCity", new { id = cityId, page }))
    </div>
}
else
{
    <p class="text-muted">No internship companies found in this city.</p>
}

<a asp-action="InternshipCompanies" asp-controller="Public" class="btn btn-secondary mt-4">← Back to Cities</a>