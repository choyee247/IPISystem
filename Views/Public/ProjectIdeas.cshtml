@model ProjectManagementSystem.ViewModels.ProjectIdeasViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using ProjectManagementSystem.DBModels

@{
    ViewData["Title"] = "Student Projects";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}
@{
    var requestStatuses = ViewBag.RequestStatuses as Dictionary<int, DownloadRequest>;
    var projectRequest = ViewBag.ProjectRequest as DownloadRequest;
}

<style>
    /* --- General Page & Typography --- */
    body {
        font-family: "Segoe UI", sans-serif;
        background-color: #f9f8ff;
    }

    h2 {
        color: #4b0082;
    }

    /* --- Header Stats --- */
    .header-flex {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .small-dashboard-card {
        display: inline-flex;
        align-items: center;
        background: #f3e9ff;
        border-radius: 0.5rem;
        padding: 0.4rem 0.8rem;
        box-shadow: 0 2px 6px rgba(140, 93, 209, 0.15);
        min-width: 150px;
        gap: 0.5rem;
        font-weight: 600;
        color: #4b0082;
        cursor: default;
    }

    .small-dashboard-icon {
        font-size: 1.5rem;
        color: #8c5dd1;
    }

    /* --- Filters & Search --- */
    .filter-select {
        max-width: 320px;
        border-color: #8c5dd1;
        color: #8c5dd1;
    }

    .filter-select:focus {
        border-color: #8c5dd1;
        box-shadow: 0 0 0 0.2rem rgba(140, 93, 209, 0.25);
    }

    #searchInput {
        border: 1px solid #8c5dd1;
        border-radius: 0.375rem;
        padding: 0.375rem 0.75rem;
    }

    #searchSuggestions {
        background-color: #fff;
        border: 1px solid #ccc;
        max-height: 200px;
        overflow-y: auto;
        border-top: none;
        position: absolute;
        z-index: 1050;
        width: 100%;
        border-radius: 0 0 0.375rem 0.375rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    /* --- Project Cards --- */
    .project-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
        border-radius: 0.75rem;
        background-color: #f8f6ff;
        border: 1px solid #8c5dd1;
        box-shadow: 0 4px 8px rgba(140, 93, 209, 0.1);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%;
    }

    .project-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 16px 40px rgba(140, 93, 209, 0.3);
        z-index: 5;
    }

    .card-body {
        padding: 1rem;
    }

    .card-title {
        font-size: 1.3rem;
        color: #8c5dd1;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .card-subtitle {
        font-size: 0.95rem;
        color: #6b46c1;
        margin-bottom: 0.5rem;
    }

    .card-text {
        font-size: 0.9rem;
        color: #1e293b;
        margin-bottom: 0.25rem;
    }

    .badge.bg-info {
        background-color: #e6d8ff !important;
        color: #5a3fa3 !important;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .btn-primary, .btn-success, .btn-warning, .btn-outline-secondary {
        border-radius: 0.375rem;
    }

    /* --- File List --- */
    .file-list li {
        list-style: none;
        margin-bottom: 6px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
    }

    .file-icon {
        font-size: 1.1rem;
        color: #8c5dd1;
        flex-shrink: 0;
    }

    /* --- Pagination --- */
    ul.pagination {
        display: flex;
        flex-wrap: wrap;
        list-style-type: none;
        padding-left: 0;
        margin: 0;
        gap: 6px;
    }

    ul.pagination li a,
    ul.pagination li span {
        display: block;
        padding: 0.4rem 0.8rem;
        color: #8c5dd1;
        text-decoration: none;
        border: 1px solid #8c5dd1;
        border-radius: 0.375rem;
        transition: all 0.2s ease;
    }

    ul.pagination li a:hover:not(.disabled) {
        background-color: #8c5dd1;
        color: white;
        border-color: #8c5dd1;
    }

    ul.pagination li.active span {
        background-color: #8c5dd1;
        color: white;
        border-color: #8c5dd1;
    }

    ul.pagination li.disabled span {
        color: #a6a6a6;
        border-color: #e0e0e0;
    }

    /* Responsive Grid */
    @@media (min-width: 992px) {
        .project-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
        }
    }

    @@media (min-width: 768px) and (max-width: 991px) {
        .project-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1.5rem;
        }
    }

    @@media (max-width: 767px) {
        .project-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
        }
    }
</style>

<div class="header-flex">
    <h2>@ViewData["Title"]</h2>
    <div class="small-dashboard-card" title="Total Projects">
        <i class="bi bi-journal-code small-dashboard-icon"></i>
        <span>Total Projects: @Model.TotalProjects</span>
    </div> 
</div>

<form method="get" asp-action="ProjectIdeas" id="filterForm" class="mb-4" autocomplete="off">
    <div class="row g-2 align-items-center position-relative">
        <div class="col-auto">
            <select id="academicYearDropdown" name="academicYearId" class="form-select filter-select" onchange="submitFilterForm()">
                <option value="">-- Filter by Academic Year --</option>
                @foreach (var ay in Model.AcademicYears)
                {
                    <option value="@ay.Value" >@ay.Text</option>
                }
            </select>
        </div>

        <div class="col-auto">
            <select id="projectTypeDropdown" name="projectTypeId" class="form-select filter-select" onchange="loadLanguages()">
                <option value="">-- Filter by Project Type --</option>
                @foreach (var type in Model.ProjectTypes)
                {
                    <option value="@type.Value">@type.Text</option>
                }
            </select>
        </div>

        <div class="col-auto">
            <select id="languageDropdown" name="languageId" class="form-select filter-select" onchange="submitFilterForm()">
                <option value="">-- Filter by Language --</option>
                @foreach (var lang in Model.Languages)
                {
                    <option value="@lang.Value">@lang.Text</option>
                }
            </select>
        </div>

        <div class="col-auto position-relative" style="min-width: 250px;">
            <input type="text" id="searchInput" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search projects..." />
            <div id="searchSuggestions" class="list-group"></div>
        </div>

        <div class="col-auto">
            <button class="btn btn-outline-primary" type="submit">
                <i class="bi bi-search"></i>
            </button>
        </div>

        @if (Model.SelectedProjectTypeId.HasValue || Model.SelectedLanguageId.HasValue || !string.IsNullOrWhiteSpace(Model.SearchTerm))
        {
            <div class="col-auto">
                <a asp-action="ProjectIdeas" class="btn btn-outline-secondary">
                    ← Back to All Projects
                </a>
            </div>
        }
    </div>
</form>

@if (!Model.Projects.Any())
{
    <p class="text-muted fst-italic fs-5">No projects found for the selected filters.</p>
}
else
{
    <div class="project-grid">
        @foreach (var project in Model.Projects)
        {
            <div class="project-card">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@project.ProjectName</h5>
                    <h6 class="card-subtitle mb-2">Student: @project.StudentPk?.StudentName</h6>

                    <p class="card-text mb-1"><span class="badge bg-info">Supervisor: @project.SupervisorName</span></p>
                    <p class="card-text mb-1"><span class="badge bg-info">Academic Year: @project.StudentPk.AcademicYearPk.YearRange</span></p>
                    <p class="card-text mb-1"><span class="badge bg-info">Project Type: @project.ProjectTypePk?.TypeName</span></p>
                    <p class="card-text mb-1"><span class="badge bg-info">Language: @project.LanguagePk.LanguageName</span></p>
                    <p class="card-text mb-1"><span class="badge bg-info">Company: @project.CompanyPk?.CompanyName</span></p>

                    @if (project.ProjectFiles != null && project.ProjectFiles.Any())
                    {
                        <div class="mt-3">
                            @if (ViewBag.ProjectRequestStatuses != null &&
                           ViewBag.ProjectRequestStatuses.ContainsKey(project.ProjectPkId))
                            {
                                var req = ViewBag.ProjectRequestStatuses[project.ProjectPkId];

                                if (req.IsBlocked)
                                {
                                    <span class="badge bg-danger">Blocked</span>
                                }
                                else if (req.IsApproved == true)
                                {
                                    <a asp-controller="Public"
                                       asp-action="DownloadProject"
                                       asp-route-requestId="@req.DownloadRequestPkId"
                                       class="btn btn-success btn-sm">
                                        Download
                                    </a>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                            }
                            else
                            {
                                <a asp-action="RequestDownload"
                                   asp-route-fileId="@project.ProjectFiles.First().ProjectFilePkId"
                                   class="btn btn-warning btn-sm">
                                    Request Download
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted fst-italic mt-3">No files uploaded.</p>
                    }
                </div>
            </div>
        }
    </div>
}

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center flex-wrap gap-2">
            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link" asp-action="ProjectIdeas" asp-route-projectTypeId="@Model.SelectedProjectTypeId" asp-route-languageId="@Model.SelectedLanguageId" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="@(Model.CurrentPage - 1)">
                    &laquo;
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")" aria-current="@(i == Model.CurrentPage ? "page" : null)">
                    <a class="page-link" asp-action="ProjectIdeas" asp-route-projectTypeId="@Model.SelectedProjectTypeId" asp-route-languageId="@Model.SelectedLanguageId" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="@i">@i</a>
                </li>
            }

            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="ProjectIdeas" asp-route-projectTypeId="@Model.SelectedProjectTypeId" asp-route-languageId="@Model.SelectedLanguageId" asp-route-searchTerm="@Model.SearchTerm" asp-route-page="@(Model.CurrentPage + 1)">
                     &raquo;
                </a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        function loadLanguages() {
            var projectTypeId = document.getElementById("projectTypeDropdown").value;
            var languageDropdown = document.getElementById("languageDropdown");

            if (!projectTypeId) {
                languageDropdown.innerHTML = '<option value="">-- Filter by Language --</option>';
                submitFilterForm();
                return;
            }

            fetch(`/Public/GetLanguagesByProjectTypeUsedInProjects?projectTypeId=${projectTypeId}`)
                .then(response => response.json())
                .then(data => {
                    languageDropdown.innerHTML = '<option value="">-- Filter by Language --</option>';
                    data.forEach(lang => {
                        let option = document.createElement("option");
                        option.value = lang.value;
                        option.text = lang.text;
                        languageDropdown.appendChild(option);
                    });
                    submitFilterForm();
                })
                .catch(error => console.error('Failed to load languages:', error));
        }

        function submitFilterForm() {
            document.getElementById("filterForm").submit();
        }

        const searchInput = document.getElementById("searchInput");
        const suggestionsBox = document.getElementById("searchSuggestions");

        searchInput.addEventListener("input", function () {
            const term = this.value.trim();
            if (term.length < 2) { suggestionsBox.innerHTML = ""; return; }

            fetch(`/Public/SearchSuggestions?term=${encodeURIComponent(term)}`)
                .then(response => response.json())
                .then(data => {
                    suggestionsBox.innerHTML = "";
                    data.forEach(item => {
                        const option = document.createElement("a");
                        option.classList.add("list-group-item", "list-group-item-action");
                        option.textContent = item;
                        option.href = "#";
                        option.addEventListener("click", function (e) {
                            e.preventDefault();
                            searchInput.value = item;
                            suggestionsBox.innerHTML = "";
                            submitFilterForm();
                        });
                        suggestionsBox.appendChild(option);
                    });
                })
                .catch(err => { console.error("Autocomplete failed:", err); suggestionsBox.innerHTML = ""; });
        });

        document.addEventListener("click", function (e) {
            if (!searchInput.contains(e.target) && !suggestionsBox.contains(e.target)) {
                suggestionsBox.innerHTML = "";
            }
        });
    </script>
}