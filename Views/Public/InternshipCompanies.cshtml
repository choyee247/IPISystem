@model ProjectManagementSystem.ViewModels.CityListViewModel

@{
    ViewData["Title"] = "Internship by State / Region";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<style>
    .card {
        border: 1px solid #8c5dd1;
        background-color: #e4eefd;
        transition: 0.3s ease-in-out;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 18px rgba(0,0,0,0.15);
        }

    .card-title {
        color: #8c5dd1;
        font-weight: bold;
    }

    .student-badge {
        background-color: #8c5dd1;
        color: white;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.85rem;
    }

    .btn-primary {
        background-color: #8c5dd1;
        border-color: #8c5dd1;
    }

        .btn-primary:hover {
            background-color: #7b4fc7;
            border-color: #7b4fc7;
        }

    .pagination .page-item.active .page-link {
        background-color: #8c5dd1;
        border-color: #8c5dd1;
        color: white;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@ViewData["Title"]</h2>
    <div class="student-badge">
        Total States: @Model.Cities.Count()
    </div>
</div>

@if (!Model.Cities.Any())
{
    <p class="text-muted">No internship states found.</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var city in Model.Cities)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">

                    @if (!string.IsNullOrEmpty(city.ImageFileName))
                    {
                        <img src="@Url.Content("~/images/cities/" + city.ImageFileName)"
                             class="card-img-top"
                             alt="@city.CityName"
                             style="height:200px; object-fit:cover;" />
                    }

                    <div class="card-body d-flex flex-column text-center">
                        <h5 class="card-title">@city.CityName</h5>

                        <div class="mb-3">
                            <span class="student-badge">
                                @city.TotalStudents Students
                            </span>
                        </div>

                        <a asp-action="CompaniesByCity"
                           asp-route-id="@city.CityPkId"
                           class="btn btn-primary mt-auto">
                            Explore
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">

                <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="InternshipCompanies"
                       asp-route-page="@(Model.CurrentPage - 1)">
                        Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="InternshipCompanies"
                           asp-route-page="@i">@i</a>
                    </li>
                }

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="InternshipCompanies"
                       asp-route-page="@(Model.CurrentPage + 1)">
                        Next
                    </a>
                </li>

            </ul>
        </nav>
    }
}